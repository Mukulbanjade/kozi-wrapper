{
  "appId": "com.kozi.rest",
  "appName": "SideQuest",
  "webDir": "www",

  "server": {
    "allowNavigation": [
      "www.side-quest.site",
      "side-quest.site"
    ]
  },

  "ios": {
    "backgroundColor": "#ffffff"
  },

  "android": {
    "backgroundColor": "#ffffff"
  },

  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 0,
      "launchAutoHide": true,
      "backgroundColor": "#ffffffff",
      "showSpinner": false,
      "splashFullScreen": false,
      "splashImmersive": false,
      "fadeOutDuration": 0
    },
    "FirebaseMessaging": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  },

  "packageClassList": [
    "CAPCameraPlugin",
    "FirebaseMessagingPlugin"
  ]
}